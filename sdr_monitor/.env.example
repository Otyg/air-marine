# Core service settings
SDR_MONITOR_SERVICE_NAME=sdr-monitor
SDR_MONITOR_LOG_LEVEL=INFO

# Scanner timing windows (seconds)
SDR_MONITOR_ADSB_WINDOW_SECONDS=8
SDR_MONITOR_OGN_WINDOW_SECONDS=0
SDR_MONITOR_AIS_WINDOW_SECONDS=12

# Freshness thresholds (seconds since last_seen)
SDR_MONITOR_FRESH_SECONDS=30
SDR_MONITOR_AGING_SECONDS=120

# In-memory target position history size
SDR_MONITOR_MAX_POSITIONS_PER_TARGET=5

# Decoder integration defaults
# OGN TCP feed can carry OGN, FLARM, and ADS-L style APRS traffic.
SDR_MONITOR_READSB_AIRCRAFT_JSON=/run/readsb/aircraft.json
SDR_MONITOR_OGN_TCP_HOST=127.0.0.1
SDR_MONITOR_OGN_TCP_PORT=50001
SDR_MONITOR_AIS_TCP_HOST=127.0.0.1
SDR_MONITOR_AIS_TCP_PORT=10110

# v2 backend options
SDR_MONITOR_RADIO_BACKEND=legacy

# ADS-B inproc source (readsb|rtl_tcp) used when RADIO_BACKEND=inproc
SDR_MONITOR_ADSB_INPROC_SOURCE=readsb
SDR_MONITOR_ADSB_INPROC_RTL_HOST=127.0.0.1
SDR_MONITOR_ADSB_INPROC_RTL_PORT=1234
SDR_MONITOR_ADSB_INPROC_SAMPLE_RATE=2000000
SDR_MONITOR_ADSB_INPROC_GAIN=30
SDR_MONITOR_ADSB_INPROC_FREQUENCY_HZ=1090000000

# AIS inproc source (tcp|rtl_tcp) used when RADIO_BACKEND=inproc
SDR_MONITOR_AIS_INPROC_SOURCE=tcp
SDR_MONITOR_AIS_INPROC_RTL_HOST=127.0.0.1
SDR_MONITOR_AIS_INPROC_RTL_PORT=1234
SDR_MONITOR_AIS_INPROC_SAMPLE_RATE=288000
SDR_MONITOR_AIS_INPROC_GAIN=30

# Per-band retune frequencies used by v2 scanner windows
SDR_MONITOR_AIS_FREQUENCY_HZ=162025000
SDR_MONITOR_OGN_FREQUENCY_HZ=868200000
SDR_MONITOR_DSC_FREQUENCY_HZ=156525000

# Persistence and API
SDR_MONITOR_SQLITE_PATH=./data/sdr_monitor.sqlite3
SDR_MONITOR_API_HOST=0.0.0.0
SDR_MONITOR_API_PORT=8000
SDR_MONITOR_FIXED_OBJECTS_PATH=./data/fixed_objects.json

# Map background layer
# Choose "hydro" for Hydrografi Direkt or "elevation" for the Markhöjd Direkt track.
SDR_MONITOR_MAP_SOURCE=hydro
SDR_MONITOR_MAP_CACHE_TTL_SECONDS=600
SDR_MONITOR_MAP_CACHE_DIR=./data/map/cache

# Hydrografi Direkt (OGC API Features)
SDR_MONITOR_HYDRO_BASE_URL=https://api.lantmateriet.se/ogc-features/v1/hydrografi
SDR_MONITOR_HYDRO_USERNAME=
SDR_MONITOR_HYDRO_PASSWORD=

# Markhöjd Direkt
SDR_MONITOR_MARKHOJD_DIRECT_BASE_URL=https://api.lantmateriet.se/distribution/produkter/markhojd/v1
SDR_MONITOR_MARKHOJD_DIRECT_USERNAME=
SDR_MONITOR_MARKHOJD_DIRECT_PASSWORD=
SDR_MONITOR_MARKHOJD_DIRECT_SRID=3006
SDR_MONITOR_MARKHOJD_DIRECT_SAMPLE_STEP_M=25
SDR_MONITOR_MARKHOJD_DIRECT_CONTOUR_INTERVAL_M=10
SDR_MONITOR_MARKHOJD_DIRECT_MAX_POINTS_PER_REQUEST=1000
