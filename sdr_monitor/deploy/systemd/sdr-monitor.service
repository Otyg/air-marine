[Unit]
Description=SDR Monitor (FastAPI + scanner)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/ABSOLUTE/PATH/TO/sdr_monitor
EnvironmentFile=/ABSOLUTE/PATH/TO/sdr_monitor/.env
ExecStart=/ABSOLUTE/PATH/TO/sdr_monitor/.venv/bin/python -m app.main
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
